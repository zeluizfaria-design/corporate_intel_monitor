# ============================================================
# Corporate Intelligence Monitor — Exemplo de configuração
# Copie para .env e preencha com suas credenciais reais
# ============================================================

# Tickers a monitorar (separados por vírgula)
TARGET_TICKERS=PETR4,VALE3,AAPL,NVDA

# Dias retroativos na coleta
DAYS_BACK=30

# Dupla listagem BR <-> US (formato JSON)
DUAL_LISTED_MAP={"VALE3":"VALE","PETR4":"PBR","ITUB4":"ITUB","BBDC4":"BBD"}

# -------------------------------------------------------
# X / TWITTER
# Obter em: https://developer.twitter.com/en/portal/dashboard
# -------------------------------------------------------
TWITTER_BEARER_TOKEN=

# -------------------------------------------------------
# REDDIT
# Criar app em: https://www.reddit.com/prefs/apps (tipo: script)
# -------------------------------------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=CorporateIntelMonitor/1.0

# -------------------------------------------------------
# DISCORD
# Criar bot em: https://discord.com/developers/applications
# Habilitar "Message Content Intent" nas configurações do bot
# IDs de canais separados por vírgula
# -------------------------------------------------------
DISCORD_BOT_TOKEN=
DISCORD_CHANNELS=123456789012345678,987654321098765432

# -------------------------------------------------------
# TELEGRAM
# Obter API ID e HASH em: https://my.telegram.org/apps
# Canais separados por vírgula (sem @)
# -------------------------------------------------------
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+5511999990000
TELEGRAM_CHANNELS=investidoresbr,bolsanoticias,valoreconomico

# -------------------------------------------------------
# LINKEDIN
# Exportar cookies após login manual:
#   python -c "from collectors.social_collector import LinkedInCollector; LinkedInCollector.export_session_helper()"
# -------------------------------------------------------
LINKEDIN_COOKIES_PATH=linkedin_cookies.json

# -------------------------------------------------------
# KALSHI  (leitura pública não requer auth; auth p/ portfólio)
# Conta em: https://kalshi.com
# -------------------------------------------------------
KALSHI_EMAIL=
KALSHI_PASSWORD=

# -------------------------------------------------------
# BETFAIR EXCHANGE
# App Key gratuita (delayed): https://developer.betfair.com
# -------------------------------------------------------
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_APP_KEY=

# -------------------------------------------------------
# DERIV  (app_id 1089 = público para leitura sem conta)
# Crie o seu em: https://app.deriv.com/account/api-token
# -------------------------------------------------------
DERIV_APP_ID=1089
DERIV_TOKEN=

# -------------------------------------------------------
# IQ OPTION  (API não oficial — prefira Deriv como alternativa)
# -------------------------------------------------------
IQ_OPTION_EMAIL=
IQ_OPTION_PASSWORD=

# -------------------------------------------------------
# CLAUDE API (síntese de briefings diários)
# Obter em: https://console.anthropic.com
# -------------------------------------------------------
ANTHROPIC_API_KEY=
